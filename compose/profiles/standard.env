# Standard profile: 2 GB+ RAM hosts with headroom for load spikes.

RESOURCE_PROFILE=standard

DB_MEM_LIMIT=192m
DB_CPU_LIMIT=1.00
REDIS_MEM_LIMIT=64m
REDIS_CPU_LIMIT=0.50
TSETMC_API_MEM_LIMIT=224m
TSETMC_API_CPU_LIMIT=2.00
CODAL_API_MEM_LIMIT=192m
CODAL_API_CPU_LIMIT=2.00
BOURSE_AZMA_API_MEM_LIMIT=384m
BOURSE_AZMA_API_CPU_LIMIT=2.00
BOURSE_AZMA_UI_MEM_LIMIT=32m
BOURSE_AZMA_UI_CPU_LIMIT=0.50

POSTGRES_MAX_CONNECTIONS=30
POSTGRES_SHARED_BUFFERS=48MB
POSTGRES_EFFECTIVE_CACHE_SIZE=128MB
POSTGRES_WORK_MEM=2MB
POSTGRES_MAINTENANCE_WORK_MEM=24MB

REDIS_MAXMEMORY=48mb

TSETMC_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=150 -XX:+ParallelRefProcEnabled -XX:+UseStringDeduplication -XX:+UseContainerSupport -Xms64m -Xmx128m -Xss256k -XX:MaxMetaspaceSize=80m -XX:MaxDirectMemorySize=32m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
CODAL_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=150 -XX:+ParallelRefProcEnabled -XX:+UseStringDeduplication -XX:+UseContainerSupport -Xms48m -Xmx112m -Xss256k -XX:MaxMetaspaceSize=72m -XX:MaxDirectMemorySize=32m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
BOURSE_AZMA_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=150 -XX:+ParallelRefProcEnabled -XX:+UseStringDeduplication -XX:+UseContainerSupport -Xms96m -Xmx192m -Xss256k -XX:MaxMetaspaceSize=128m -XX:MaxDirectMemorySize=32m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"

BOURSE_AZMA_API_HIKARI_MAX_POOL=10
BOURSE_AZMA_API_HIKARI_MIN_IDLE=2
BOURSE_AZMA_API_REDIS_POOL_MAX_ACTIVE=8
BOURSE_AZMA_API_REDIS_POOL_MIN_IDLE=1
TSETMC_API_REDIS_POOL_MAX_ACTIVE=8
TSETMC_API_REDIS_POOL_MIN_IDLE=1
CODAL_API_REDIS_POOL_MAX_ACTIVE=8
CODAL_API_REDIS_POOL_MIN_IDLE=1

SERVER_TOMCAT_MAX_CONNECTIONS=200
SERVER_TOMCAT_ACCEPT_COUNT=40
SERVER_TOMCAT_THREADS_MAX=100
SERVER_TOMCAT_THREADS_MIN_SPARE=5
