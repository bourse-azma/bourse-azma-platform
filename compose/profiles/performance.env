# Performance profile: 4+ CPU cores and 8+ GB RAM.
# Hard memory limits total 2752 MB; JVMs and pools get room to scale under load.

RESOURCE_PROFILE=performance

DB_MEM_LIMIT=512m
DB_CPU_LIMIT=2.00
REDIS_MEM_LIMIT=256m
REDIS_CPU_LIMIT=1.00
TSETMC_API_MEM_LIMIT=512m
TSETMC_API_CPU_LIMIT=4.00
CODAL_API_MEM_LIMIT=384m
CODAL_API_CPU_LIMIT=4.00
BOURSE_AZMA_API_MEM_LIMIT=1024m
BOURSE_AZMA_API_CPU_LIMIT=4.00
BOURSE_AZMA_UI_MEM_LIMIT=64m
BOURSE_AZMA_UI_CPU_LIMIT=1.00

POSTGRES_MAX_CONNECTIONS=60
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=384MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB

REDIS_MAXMEMORY=192mb

TSETMC_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+ParallelRefProcEnabled -XX:+UseStringDeduplication -XX:+UseContainerSupport -Xms128m -Xmx256m -Xss512k -XX:MaxMetaspaceSize=128m -XX:MaxDirectMemorySize=64m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
CODAL_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+ParallelRefProcEnabled -XX:+UseStringDeduplication -XX:+UseContainerSupport -Xms96m -Xmx192m -Xss512k -XX:MaxMetaspaceSize=128m -XX:MaxDirectMemorySize=64m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
BOURSE_AZMA_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=100 -XX:+ParallelRefProcEnabled -XX:+UseStringDeduplication -XX:+UseContainerSupport -Xms256m -Xmx512m -Xss512k -XX:MaxMetaspaceSize=192m -XX:MaxDirectMemorySize=64m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"

BOURSE_AZMA_API_HIKARI_MAX_POOL=20
BOURSE_AZMA_API_HIKARI_MIN_IDLE=4
BOURSE_AZMA_API_REDIS_POOL_MAX_ACTIVE=16
BOURSE_AZMA_API_REDIS_POOL_MIN_IDLE=2
TSETMC_API_REDIS_POOL_MAX_ACTIVE=16
TSETMC_API_REDIS_POOL_MIN_IDLE=2
CODAL_API_REDIS_POOL_MAX_ACTIVE=16
CODAL_API_REDIS_POOL_MIN_IDLE=2

SERVER_TOMCAT_MAX_CONNECTIONS=500
SERVER_TOMCAT_ACCEPT_COUNT=100
SERVER_TOMCAT_THREADS_MAX=200
SERVER_TOMCAT_THREADS_MIN_SPARE=10
