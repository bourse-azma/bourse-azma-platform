# Low profile: balanced runtime for 2-core / 2 GB hosts.
# Hard memory limits total 1168 MB, leaving room for Docker and the OS.

RESOURCE_PROFILE=low

DB_MEM_LIMIT=192m
DB_CPU_LIMIT=0.75
REDIS_MEM_LIMIT=64m
REDIS_CPU_LIMIT=0.35
TSETMC_API_MEM_LIMIT=224m
TSETMC_API_CPU_LIMIT=1.00
CODAL_API_MEM_LIMIT=192m
CODAL_API_CPU_LIMIT=1.00
BOURSE_AZMA_API_MEM_LIMIT=448m
BOURSE_AZMA_API_CPU_LIMIT=1.25
BOURSE_AZMA_UI_MEM_LIMIT=48m
BOURSE_AZMA_UI_CPU_LIMIT=0.35

POSTGRES_MAX_CONNECTIONS=22
POSTGRES_SHARED_BUFFERS=48MB
POSTGRES_EFFECTIVE_CACHE_SIZE=128MB
POSTGRES_WORK_MEM=2MB
POSTGRES_MAINTENANCE_WORK_MEM=12MB

REDIS_MAXMEMORY=40mb

TSETMC_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+ParallelRefProcEnabled -XX:+UseContainerSupport -Xms48m -Xmx112m -Xss256k -XX:MaxMetaspaceSize=80m -XX:MaxDirectMemorySize=24m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
CODAL_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+ParallelRefProcEnabled -XX:+UseContainerSupport -Xms48m -Xmx96m -Xss256k -XX:MaxMetaspaceSize=72m -XX:MaxDirectMemorySize=24m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
BOURSE_AZMA_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+ParallelRefProcEnabled -XX:+UseContainerSupport -Xms96m -Xmx224m -Xss256k -XX:MaxMetaspaceSize=128m -XX:MaxDirectMemorySize=32m -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"

BOURSE_AZMA_API_HIKARI_MAX_POOL=6
BOURSE_AZMA_API_HIKARI_MIN_IDLE=1
BOURSE_AZMA_API_REDIS_POOL_MAX_ACTIVE=6
BOURSE_AZMA_API_REDIS_POOL_MIN_IDLE=0
TSETMC_API_REDIS_POOL_MAX_ACTIVE=4
TSETMC_API_REDIS_POOL_MIN_IDLE=0
CODAL_API_REDIS_POOL_MAX_ACTIVE=4
CODAL_API_REDIS_POOL_MIN_IDLE=0

SERVER_TOMCAT_MAX_CONNECTIONS=120
SERVER_TOMCAT_ACCEPT_COUNT=25
SERVER_TOMCAT_THREADS_MAX=40
SERVER_TOMCAT_THREADS_MIN_SPARE=3
