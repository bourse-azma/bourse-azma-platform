# Low profile: 1-2 GB RAM hosts. Build/startup peak capped via staggered JVM boot.
# Target idle RSS: ~450-600 MB. Total limits: ~768 MB.

RESOURCE_PROFILE=low

DB_MEM_LIMIT=128m
DB_CPU_LIMIT=0.35
REDIS_MEM_LIMIT=40m
REDIS_CPU_LIMIT=0.12
TSETMC_API_MEM_LIMIT=144m
TSETMC_API_CPU_LIMIT=0.30
CODAL_API_MEM_LIMIT=128m
CODAL_API_CPU_LIMIT=0.25
BOURSE_AZMA_API_MEM_LIMIT=256m
BOURSE_AZMA_API_CPU_LIMIT=0.35
BOURSE_AZMA_UI_MEM_LIMIT=28m
BOURSE_AZMA_UI_CPU_LIMIT=0.10

POSTGRES_MAX_CONNECTIONS=22
POSTGRES_SHARED_BUFFERS=24MB
POSTGRES_EFFECTIVE_CACHE_SIZE=72MB
POSTGRES_WORK_MEM=2MB
POSTGRES_MAINTENANCE_WORK_MEM=12MB

REDIS_MAXMEMORY=24mb

TSETMC_API_JAVA_OPTS="-XX:+UseSerialGC -XX:+UseContainerSupport -Xms32m -Xmx80m -Xss256k -XX:MaxMetaspaceSize=56m -XX:MaxDirectMemorySize=24m -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
CODAL_API_JAVA_OPTS="-XX:+UseSerialGC -XX:+UseContainerSupport -Xms32m -Xmx80m -Xss256k -XX:MaxMetaspaceSize=56m -XX:MaxDirectMemorySize=24m -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
BOURSE_AZMA_API_JAVA_OPTS="-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseContainerSupport -Xms48m -Xmx128m -Xss256k -XX:MaxMetaspaceSize=96m -XX:MaxDirectMemorySize=24m -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"

BOURSE_AZMA_API_HIKARI_MAX_POOL=6
BOURSE_AZMA_API_HIKARI_MIN_IDLE=1
BOURSE_AZMA_API_REDIS_POOL_MAX_ACTIVE=6
BOURSE_AZMA_API_REDIS_POOL_MIN_IDLE=0
TSETMC_API_REDIS_POOL_MAX_ACTIVE=4
TSETMC_API_REDIS_POOL_MIN_IDLE=0
CODAL_API_REDIS_POOL_MAX_ACTIVE=4
CODAL_API_REDIS_POOL_MIN_IDLE=0

SERVER_TOMCAT_MAX_CONNECTIONS=120
SERVER_TOMCAT_ACCEPT_COUNT=25
SERVER_TOMCAT_THREADS_MAX=40
SERVER_TOMCAT_THREADS_MIN_SPARE=3

SPRING_MAIN_LAZY_INITIALIZATION=true
