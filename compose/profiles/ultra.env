# Ultra-low profile: 1 vCPU / 1 GB RAM hosts.
# Target idle RSS: ~400-550 MB. Total limits: ~680 MB.

RESOURCE_PROFILE=ultra

DB_MEM_LIMIT=96m
DB_CPU_LIMIT=0.30
REDIS_MEM_LIMIT=32m
REDIS_CPU_LIMIT=0.10
TSETMC_API_MEM_LIMIT=144m
TSETMC_API_CPU_LIMIT=0.30
CODAL_API_MEM_LIMIT=144m
CODAL_API_CPU_LIMIT=0.20
BOURSE_AZMA_API_MEM_LIMIT=288m
BOURSE_AZMA_API_CPU_LIMIT=0.30
BOURSE_AZMA_UI_MEM_LIMIT=24m
BOURSE_AZMA_UI_CPU_LIMIT=0.08

POSTGRES_MAX_CONNECTIONS=20
POSTGRES_SHARED_BUFFERS=16MB
POSTGRES_EFFECTIVE_CACHE_SIZE=48MB
POSTGRES_WORK_MEM=1MB
POSTGRES_MAINTENANCE_WORK_MEM=8MB

REDIS_MAXMEMORY=16mb

TSETMC_API_JAVA_OPTS="-XX:+UseSerialGC -XX:+UseContainerSupport -Xms24m -Xmx56m -Xss256k -XX:MaxMetaspaceSize=72m -XX:MaxDirectMemorySize=16m -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
CODAL_API_JAVA_OPTS="-XX:+UseSerialGC -XX:+UseContainerSupport -Xms24m -Xmx56m -Xss256k -XX:MaxMetaspaceSize=72m -XX:MaxDirectMemorySize=16m -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"
BOURSE_AZMA_API_JAVA_OPTS="-XX:+UseSerialGC -XX:+UseContainerSupport -Xms48m -Xmx112m -Xss256k -XX:MaxMetaspaceSize=128m -XX:MaxDirectMemorySize=16m -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError -Djava.security.egd=file:/dev/./urandom -Dfile.encoding=UTF-8"

BOURSE_AZMA_API_HIKARI_MAX_POOL=4
BOURSE_AZMA_API_HIKARI_MIN_IDLE=1
BOURSE_AZMA_API_REDIS_POOL_MAX_ACTIVE=4
BOURSE_AZMA_API_REDIS_POOL_MIN_IDLE=0
TSETMC_API_REDIS_POOL_MAX_ACTIVE=3
TSETMC_API_REDIS_POOL_MIN_IDLE=0
CODAL_API_REDIS_POOL_MAX_ACTIVE=3
CODAL_API_REDIS_POOL_MIN_IDLE=0

SERVER_TOMCAT_MAX_CONNECTIONS=80
SERVER_TOMCAT_ACCEPT_COUNT=20
SERVER_TOMCAT_THREADS_MAX=25
SERVER_TOMCAT_THREADS_MIN_SPARE=2
