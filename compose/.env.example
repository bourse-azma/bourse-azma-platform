# Resource profiles for Bourse Azma Docker Compose.
#
# Quick start (auto-detect host RAM):
#   ../scripts/configure-resources.sh --force
#   docker compose up --build -d
#
# Manual profile selection:
#   RESOURCE_PROFILE=ultra ../scripts/configure-resources.sh --force
#
# Profiles live in profiles/:
#   ultra    - 1 vCPU / 1 GB RAM (~584 MB limits, ~350-500 MB idle target)
#   low      - 1-2 GB RAM (~768 MB limits, build/startup peak < 2 GB)
#   standard - 2 GB+ RAM (more headroom under load)

RESOURCE_PROFILE=ultra

# Run configure-resources.sh to populate the rest:
#   ./scripts/configure-resources.sh --force

SPRING_LIFECYCLE_TIMEOUT_PER_SHUTDOWN_PHASE=20s

MAVEN_BUILD_HEAP_MB=384
NODE_BUILD_HEAP_MB=256
COMPOSE_BUILD_PARALLEL=0
